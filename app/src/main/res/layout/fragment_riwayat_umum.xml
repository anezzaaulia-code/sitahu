<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_screen"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/btnBackRiwayatUmum" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/bg_icon_soft" android:gravity="center" android:text="←" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Riwayat Umum" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Gabungan penjualan, produksi, dan pengeluaran" android:textColor="@color/text_secondary" android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/tvRingkasanRiwayat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="0 aktivitas tercatat" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRiwayatUmum" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="16dp" android:layout_weight="1" android:clipToPadding="false" android:paddingBottom="24dp" />
</LinearLayout>
