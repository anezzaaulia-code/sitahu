<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollPenjualan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_screen"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <TextView android:id="@+id/btnBack" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Penjualan" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Ringkasan penjualan harian dan rekap" android:textColor="@color/text_secondary" android:textSize="14sp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_summary_panel" android:orientation="vertical" android:padding="18dp">
            <TextView android:id="@+id/tvTanggalRekap" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Penjualan hari ini" android:textColor="#E6FFFFFF" android:textSize="12sp" />
            <TextView android:id="@+id/tvTotalRekap" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Rp0" android:textColor="@android:color/white" android:textSize="30sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal" android:weightSum="2">
                <TextView android:id="@+id/tvPenjualanRingkas1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_mini_card" android:padding="12dp" android:text="Total item: 0 pcs" android:textColor="@android:color/white" android:textSize="12sp" />
                <TextView android:id="@+id/tvPenjualanRingkas2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_mini_card" android:padding="12dp" android:text="Transaksi: 0" android:textColor="@android:color/white" android:textSize="12sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal" android:weightSum="2">
                <TextView android:id="@+id/tvPenjualanRingkas3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_mini_card" android:padding="12dp" android:text="Produk terjual: 0 jenis" android:textColor="@android:color/white" android:textSize="12sp" />
                <TextView android:id="@+id/tvJumlahItem" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_mini_card" android:padding="12dp" android:text="Pengeluaran hari ini: Rp0" android:textColor="@android:color/white" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal" android:weightSum="2">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnShortcutInputPenjualan" android:layout_width="0dp" android:layout_height="46dp" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_button_gold" android:text="Tambah Penjualan" android:textAllCaps="false" android:textColor="@color/white" android:textSize="13sp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnShortcutRiwayatPenjualan" android:layout_width="0dp" android:layout_height="46dp" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_button_soft" android:text="Riwayat Penjualan" android:textAllCaps="false" android:textColor="@color/white" android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/panelFormPenjualan" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" />
        <LinearLayout android:id="@+id/panelRiwayatPenjualan" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Transaksi terbaru" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
        <LinearLayout android:id="@+id/layoutRecentPenjualan" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
